# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only. Never expose to the browser.
# Used for admin provisioning scripts, the handle_new_user trigger fallback,
# and supabase.auth.admin.generateLink() in the signup / password-reset flows.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend (server only). Domain recyclinggroup.com must be verified in Resend.
RESEND_API_KEY=re_your_key_here
EMAIL_FROM="American Resources <noreply@recyclinggroup.com>"
EMAIL_REPLY_TO=hello@recyclinggroup.com
EMAIL_ADMIN_NOTIFICATIONS=info@recyclinggroup.com

# Used in generateLink redirect_to and email CTA URLs. No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics (GA4 measurement ID, starts with G-)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
